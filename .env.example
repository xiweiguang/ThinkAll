# ============================================================
# 数据可视化系统 - 环境变量配置
# 使用说明：复制本文件为 .env，并根据实际环境修改配置值
# 命令：copy .env.example .env
# ============================================================

# ------------------------------------------------------------
# 应用配置
# ------------------------------------------------------------

# 应用名称（用于日志和页面标题显示）
APP_NAME=数据可视化

# 服务端口号（后端 Flask 监听端口）
APP_PORT=3001

# ------------------------------------------------------------
# 数据库配置（MySQL）
# ------------------------------------------------------------

# 数据库主机地址
DB_HOST=localhost

# 数据库端口号
DB_PORT=3306

# 数据库用户名
DB_USER=root

# 数据库密码（⚠️ 请替换为实际密码，切勿使用默认值或提交到版本控制）
DB_PASSWORD=your_password_here

# 数据库名称（首次启动会自动创建并初始化表结构）
DB_NAME=data_vis

# 数据库连接池配置
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=10

# ------------------------------------------------------------
# JWT 配置
# ------------------------------------------------------------

# JWT 密钥（⚠️ 安全提示：请务必替换为随机字符串！建议使用 32 位以上的随机字符）
# 生成方式示例（Python）：python -c "import secrets; print(secrets.token_hex(32))"
# 生成方式示例（PowerShell）：-join ((48..57)+(65..90)+(97..122) | Get-Random -Count 32 | % {[char]$_})
JWT_SECRET=your_jwt_secret_key_here

# JWT 过期时间（支持格式：60s=60秒, 10m=10分钟, 2h=2小时, 7d=7天）
JWT_EXPIRES_IN=24h

# ------------------------------------------------------------
# 数据源加密配置
# ------------------------------------------------------------

# 数据源密码加密密钥（⚠️ 安全提示：请务必替换为随机字符串！建议使用 32 位以上的随机字符）
# 生成方式示例（Python）：python -c "import secrets; print(secrets.token_hex(32))"
DATASOURCE_ENCRYPT_KEY=your_datasource_encrypt_key_here

# ------------------------------------------------------------
# CORS 跨域配置
# ------------------------------------------------------------

# CORS 允许的来源域名（逗号分隔，生产环境请修改为实际访问地址）
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# ------------------------------------------------------------
# Flask 运行配置
# ------------------------------------------------------------

# Flask 调试模式（⚠️ 生产环境必须设为 false）
FLASK_DEBUG=true

# 前端托管开关（离线部署时设为 true，Flask 将托管前端静态文件；开发环境设为 false）
SERVE_FRONTEND=false

# ------------------------------------------------------------
# Redis 配置（可选）
# ------------------------------------------------------------

# Redis 连接地址（生产环境建议配置，未配置时使用内存存储，重启后限流计数丢失）
# REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# 前端配置
# ------------------------------------------------------------

# API 基础地址（前端 Vite 代理配置中引用此地址）
VITE_API_BASE_URL=http://localhost:3001/api
